<Window x:Class="CyberSecurityChatBotUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="650"
        Width="950"
        Background="#0B1220">

    <Grid>

        <!-- ROW STRUCTURE -->
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#22C55E"
                BorderThickness="2"
                CornerRadius="12"
                Margin="12">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="════════════════════════════════════"
                           Foreground="#38BDF8"
                           FontFamily="Consolas"
                           FontSize="12"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="🔐 CYBERSECURITY AWARENESS BOT"
                           Foreground="#22C55E"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <TextBlock Text="🛡 Protect   🔍 Detect   ⚡ Respond"
                           Foreground="#FACC15"
                           FontSize="14"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="════════════════════════════════════"
                           Foreground="#38BDF8"
                           FontFamily="Consolas"
                           FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ================= CHAT AREA ================= -->
        <Border Grid.Row="1"
                Margin="12"
                Background="#0F172A"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="12">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel"
                            Margin="10"/>

            </ScrollViewer>
        </Border>

        <!-- ================= INPUT AREA ================= -->
        <Grid Grid.Row="2" Margin="12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     FontSize="14"
                     Padding="12"
                     Background="#111827"
                     Foreground="White"
                     BorderBrush="#22C55E"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="Send"
                    Margin="10,0,0,0"
                    Background="#22C55E"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="Send_Click"/>
        </Grid>

    </Grid>
</Window>